---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(p => p.data.tags || []))].filter(Boolean);
  
  return tags.map(tag => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
    props: { 
      tagName: tag,
      posts: posts.filter(p => p.data.tags?.some(t => t.toLowerCase() === tag.toLowerCase())) 
    },
  }));
}

const { tag } = Astro.params;
const { posts, tagName } = Astro.props;

const sorted = posts
  .map(p => ({
    url: `${import.meta.env.BASE_URL}blog/${p.id}`,
    ...p.data,
    pubDate: new Date(p.data.pubDate),
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title={`Posts tagged with "${tagName}"`}>
  <div class="container">
    <div class="hero">
      <h1>tag: <span class="tag-label">{tagName}</span></h1>
      <p class="hero-desc">
        {sorted.length} {sorted.length === 1 ? 'post' : 'posts'} tagged with "{tagName}".
      </p>
      <a href={import.meta.env.BASE_URL} class="back-link">← all posts</a>
    </div>

    <div class="posts-grid">
      {sorted.map(post => (
        <div class="post-card">
          <p class="post-card-date">{fmt(post.pubDate)}</p>
          <a href={post.url} class="post-card-title">{post.title}</a>
          {post.description && (
            <p class="post-card-desc">{post.description}</p>
          )}
          {post.tags?.length > 0 && (
            <div class="post-card-tags">
              {post.tags.map((t: string) => (
                <a href={`${import.meta.env.BASE_URL}tags/${t.toLowerCase().replace(/\s+/g, '-')}`} class="tag">{t}</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Base>

<style>
  .tag-label {
    color: var(--accent);
  }
  .back-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--accent);
  }
</style>
