---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <div class="container">
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time class="post-meta-date" datetime={pubDate.toISOString()}>
            {formattedDate}
          </time>
          {tags.length > 0 && (
            <div class="post-meta-tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</Base>
