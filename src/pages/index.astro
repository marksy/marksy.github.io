---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Fetch every .md file inside src/content/blog/
const posts = await getCollection('blog');

// Sort by date descending
const sorted = posts
  .map(p => ({
    url: `${import.meta.env.BASE_URL}blog/${p.id}`,
    ...p.data,
    pubDate: new Date(p.data.pubDate),
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="marksy.com">
  <div class="container">
    <div class="hero">
      <h1 id="hero-heading">mark chambers<span class="cursor" id="hero-cursor"></span></h1>
      <p class="hero-desc">
        Notes on software, systems, and whatever else I'm building.
      </p>
    </div>

    <script>
      const heading = document.getElementById('hero-heading');
      const originalText = "mark chambers";
      const easterEggText = "matt james";

      if (heading) {
        heading.addEventListener('click', (e) => {
          if (e.metaKey) {
            heading.firstChild.textContent = easterEggText;
          }
        });

        window.addEventListener('keyup', (e) => {
          if (e.key === 'Meta') {
            heading.firstChild.textContent = originalText;
          }
        });

        window.addEventListener('blur', () => {
          heading.firstChild.textContent = originalText;
        });
      }
    </script>

    <div class="posts-grid">
      {sorted.map(post => (
        <div class="post-card">
          <p class="post-card-date">{fmt(post.pubDate)}</p>
          <a href={post.url} class="post-card-title">{post.title}</a>
          {post.description && (
            <p class="post-card-desc">{post.description}</p>
          )}
          {post.tags?.length > 0 && (
            <div class="post-card-tags">
              {post.tags.map((t: string) => (
                <a href={`${import.meta.env.BASE_URL}tags/${t.toLowerCase().replace(/\s+/g, '-')}`} class="tag">{t}</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Base>
