---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Fetch every .md file inside src/content/blog/
const posts = await getCollection('blog');

// Sort by date descending
const sorted = posts
  .map(p => ({
    url: `${import.meta.env.BASE_URL}blog/${p.id}`,
    ...p.data,
    pubDate: new Date(p.data.pubDate),
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="marksy.com">
  <div class="container">
    <div class="hero">
      <h1>mark chambers<span class="cursor"></span></h1>
      <p class="hero-desc">
        Notes on software, systems, and whatever else I'm building.
      </p>
    </div>

    <div class="posts-grid">
      {sorted.map(post => (
        <a href={post.url} class="post-card">
          <p class="post-card-date">{fmt(post.pubDate)}</p>
          <p class="post-card-title">{post.title}</p>
          {post.description && (
            <p class="post-card-desc">{post.description}</p>
          )}
          {post.tags?.length > 0 && (
            <div class="post-card-tags">
              {post.tags.map((t: string) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</Base>
